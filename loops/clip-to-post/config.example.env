# X API v2 credentials (never commit real values)
X_API_KEY=your_api_key
X_API_SECRET=your_api_secret
X_ACCESS_TOKEN=your_access_token
X_ACCESS_TOKEN_SECRET=your_access_token_secret

# Optional: path overrides
CLIP_OUTPUT_DIR=drafts
TRANSCRIPT_DIR=drafts

# Factory LLM. Save real values in config.local.env or repo-root .env.local.
OPENAI_API_KEY=
FACTORY_LLM_PROVIDER=openai
FACTORY_LLM_FALLBACK_PROVIDER=grok
FACTORY_OPENAI_MODEL=gpt-5.6-sol
FACTORY_OPENAI_REASONING_EFFORT=medium
