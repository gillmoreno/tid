#
# TID Go API dev image
#

FROM --platform=$BUILDPLATFORM golang:1.23-alpine AS builder
WORKDIR /src/go-backend

ARG TARGETOS=linux
ARG TARGETARCH

COPY go-backend/go.mod go-backend/go.sum ./
RUN go mod download

COPY go-backend/ ./
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH:-amd64} go build -o /out/go-slice ./cmd/server

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
WORKDIR /app
COPY --from=builder /out/go-slice /usr/local/bin/go-slice

EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/go-slice"]